-			}
-
-			RGFW_dataDropCallback(win, files, count);
-			if (data)
-				XFree(data);
-
-			if (version >= 2) {
-				XEvent new_reply = { ClientMessage };
-				new_reply.xclient.window = source;
-				new_reply.xclient.message_type = XdndFinished;
-				new_reply.xclient.format = 32;
